# Copy this file to .env and fill in your own keys.
# Do not commit real keys.

# Runtime mode
AURUM_LIVE=0

# Alpha Vantage (live gold market provider)
ALPHAVANTAGE_KEY=YOUR_ALPHAVANTAGE_KEY_HERE
ALPHAVANTAGE_URL=https://www.alphavantage.co/query

# TradingView capture defaults
AURUM_ALPHA_GOLD_SYMBOL=XAU
AURUM_ALPHA_INTRADAY_FROM=XAU
AURUM_ALPHA_INTRADAY_TO=USD

# Optional vision model analysis for captured chart images
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1
AURUM_VISION_MODEL=gpt-4.1-mini
